{
  "name": "expo-supabase-mobile-starter",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "fix": "eslint . --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "env:check": "ts-node --project tsconfig.scripts.json scripts/verify-env.ts",
    "eas:login": "eas login",
    "eas:init": "eas build:configure",
    "prestart": "npm run env:check || exit 0"
  },
  "dependencies": {
    "@expo/metro-config": "^0.20.17",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.45.3",
    "expo": "^53.0.0",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.4",
    "expo-secure-store": "~14.2.3",
    "expo-status-bar": "~2.2.3",
    "metro": "^0.81.0",
    "metro-core": "^0.81.0",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eas-cli": "^16.17.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "expo-doctor": "^1.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "18.2.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  }
}
